# ===================================================================
# 博客系统后端环境变量
# 复制此文件为 .env 并填写实际值
# ===================================================================

# ---- 基本配置 ----
PORT=3000
NODE_ENV=development
APP_URL="http://localhost:5173"

# ---- 数据库 ----
# PostgreSQL 连接串 (Prisma 格式)
DATABASE_URL="postgresql://blog_admin:blog_secret_dev@localhost:5432/blog_db?schema=public"

# ---- Redis 缓存 ----
REDIS_URL="redis://localhost:6379"

# ---- RabbitMQ 消息队列 ----
RABBITMQ_URL="amqp://blog_admin:blog_mq_secret_dev@localhost:5672"

# ---- JWT 认证 ----
# ⚠️ 生产环境请使用至少 64 字符的强随机字符串
JWT_ACCESS_SECRET="dev-access-secret-change-in-production-min-32-chars"
JWT_REFRESH_SECRET="dev-refresh-secret-change-in-production-min-32-chars"
JWT_ACCESS_EXPIRES_IN="2h"
JWT_REFRESH_EXPIRES_IN="7d"
JWT_REFRESH_REMEMBER_EXPIRES_IN="30d"

# ---- SMTP 邮件服务 ----
SMTP_HOST="smtp.example.com"
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@blog.com"

# ---- 阿里云 OSS ----
OSS_REGION="oss-cn-hangzhou"
OSS_BUCKET=""
OSS_ACCESS_KEY_ID=""
OSS_ACCESS_KEY_SECRET=""
OSS_CDN_DOMAIN=""

# ---- CORS ----
CORS_ORIGIN="http://localhost:5173"
